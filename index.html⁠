<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nebulous - The Savage Mêlée</title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&family=Rajdhani:wght@500;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --gold: #FFD700; --silver: #C0C0C0; --bronze: #CD7F32;
            --bg: #03070f; --cyan: #00e5ff; --pink: #ff2d7b;
            --green: #00ff88; --purple: #a855f7; --red: #ff3333;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { 
            background: var(--bg); 
            color: #e0f0ff; 
            font-family: 'Rajdhani', sans-serif;
            overflow-x: hidden;
        }
        body::before {
            content: ''; position: fixed; inset: 0;
            background-image: 
                radial-gradient(1px 1px at 8% 12%, rgba(255,255,255,0.15) 100%, transparent),
                radial-gradient(1px 1px at 22% 55%, rgba(255,255,255,0.2) 100%, transparent),
                radial-gradient(1px 1px at 38% 7%, rgba(255,255,255,0.15) 100%, transparent),
                radial-gradient(1px 1px at 55% 70%, rgba(255,255,255,0.1) 100%, transparent),
                radial-gradient(1px 1px at 72% 30%, rgba(255,255,255,0.2) 100%, transparent),
                radial-gradient(1px 1px at 88% 85%, rgba(255,255,255,0.15) 100%, transparent),
                radial-gradient(2px 2px at 15% 90%, rgba(0,229,255,0.3) 100%, transparent),
                radial-gradient(2px 2px at 78% 45%, rgba(255,45,123,0.3) 100%, transparent),
                radial-gradient(3px 3px at 50% 50%, rgba(255,215,0,0.2) 100%, transparent);
            pointer-events: none; z-index: 0;
        }

        .container { position: relative; z-index: 1; max-width: 1200px; margin: 0 auto; padding: 20px; }
        
        header { text-align: center; margin-bottom: 50px; padding: 30px; border-bottom: 2px dashed rgba(0,229,255,0.2); }
        h1 { font-family: 'Orbitron', sans-serif; font-size: 3rem; text-transform: uppercase; color: #fff; text-shadow: 0 0 10px var(--cyan), 0 0 20px var(--cyan); margin-bottom: 10px; }
        .subtitle { color: var(--pink); font-size: 1.4rem; letter-spacing: 2px; font-weight: 700; text-shadow: 0 0 5px var(--pink); }

        .section-title { font-family: 'Orbitron', sans-serif; font-size: 2rem; color: #fff; margin: 40px 0 20px 0; display: flex; align-items: center; gap: 10px; border-left: 5px solid var(--cyan); padding-left: 15px; }

        /* Timeline Styles */
        .timeline { position: relative; padding: 20px 0; }
        .timeline::before { content: ''; position: absolute; left: 20px; top: 0; bottom: 0; width: 2px; background: linear-gradient(to bottom, var(--cyan), var(--pink), var(--purple)); }
        .timeline-item { position: relative; margin-bottom: 30px; padding-left: 50px; }
        .timeline-badge { position: absolute; left: 5px; top: 0; width: 32px; height: 32px; background: #0a1424; border: 2px solid var(--cyan); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; color: var(--cyan); font-size: 0.9rem; font-family: 'Orbitron', sans-serif; box-shadow: 0 0 10px rgba(0,229,255,0.4); }
        .timeline-content { background: rgba(10, 20, 36, 0.7); border: 1px solid rgba(0,229,255,0.15); padding: 15px 20px; border-radius: 8px; backdrop-filter: blur(5px); }
        .timeline-time { color: var(--pink); font-weight: bold; margin-bottom: 5px; font-size: 1.1rem; }
        .timeline-text { line-height: 1.5; font-size: 1.1rem; }

        /* Tables Styles */
        .grid-tables { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; margin-bottom: 40px; }
        .table-box { background: rgba(10, 20, 36, 0.8); border: 1px solid rgba(255,45,123,0.2); border-radius: 8px; padding: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.5); }
        .table-box h3 { font-family: 'Orbitron', sans-serif; color: var(--pink); margin-bottom: 12px; text-align: center; border-bottom: 1px solid rgba(255,45,123,0.2); padding-bottom: 5px; font-size: 1.2rem; }
        table { width: 100%; border-collapse: collapse; }
        th, td { padding: 8px 10px; text-align: left; font-size: 1.05rem; }
        th { color: #8ab4f8; font-weight: 700; border-bottom: 2px solid rgba(255,255,255,0.1); }
        tr:nth-child(even) { background: rgba(255,255,255,0.03); }
        .rank-col { width: 40px; font-weight: bold; text-align: center; }
        .score-col { text-align: right; color: var(--green); font-weight: bold; }

        /* Leaderboard Final Cards */
        .leaderboard-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; }
